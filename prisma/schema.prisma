generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  WRITER
  CLIENT
}

model Book {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  author      String
  price       Float
  publishers  String?  
  rating      Float?   
  reviews     String?  
  year        DateTime? 
  edition     Int?    
  achievement String?  
  category    String
  reviewsRel  Review[]  
  userId      String   
  user        User      @relation(fields: [userId], references: [id])
}

model User {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  firstName  String
  lastName   String
  role       Role
  books      Book[]   
}

model Review {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name    String    
  subject    String?  
  rating     Float?   
  message    String?  
  timestamp  DateTime  @default(now())  
  bookId     String    
  book       Book      @relation(fields: [bookId], references: [id]) 
}
